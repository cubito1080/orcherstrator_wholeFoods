NODE_ENV=development

# Orchestrator
PORT=4000
WEB_ORIGIN=http://localhost:3000
DATABASE_URL=postgres://auto_estimator:auto_estimator@localhost:5432/auto_estimator
DB_TYPE=postgres
SQLJS_DB_PATH=/tmp/auto-estimator-platform.sqlite
JWT_SECRET=change-me
WORKER_MODE=http
WORKER_HTTP_URL=http://localhost:8000/process
WORKER_WEBHOOK_SECRET=local-webhook-secret
PUBLIC_API_URL=http://localhost:4000

# AWS-compatible storage and queueing
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET=auto-estimator-local
S3_ENDPOINT=http://localhost:4566
SQS_QUEUE_URL=http://localhost:4566/000000000000/auto-estimator-jobs
SQS_ENDPOINT=http://localhost:4566
STORAGE_MODE=s3
LOCAL_STORAGE_DIR=/tmp/auto-estimator-storage

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Detector
DETECTOR_PORT=8010
DETECTOR_MODE=mock
